{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "web": {
      "type": "web",
      "entrypoint": "webui/vercel_server.py",
      "framework": "fastapi",
      "mount": "/",
      "excludeFiles": "{.env,.env.*,.claude/**,.venv312/**,.playwright-cli/**,**/.DS_Store,output*/**,docs/**,samples/**,test_*.py,webui/uploads/**,webui/runs/**,webui/quota.json,benchmark_models.py,probe_reasoning.py,**/*.command,**/*.md}"
    },
    "resume_workflow": {
      "type": "worker",
      "entrypoint": "workflows/resume_workflow.py",
      "topics": ["__wkf_*"],
      "excludeFiles": "{.env,.env.*,.claude/**,.venv312/**,.playwright-cli/**,**/.DS_Store,output*/**,docs/**,samples/**,test_*.py,webui/uploads/**,webui/runs/**,webui/quota.json,benchmark_models.py,probe_reasoning.py,**/*.command,**/*.md}"
    }
  },
  "crons": [
    {
      "path": "/api/maintenance/cleanup",
      "schedule": "0 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ]
}
